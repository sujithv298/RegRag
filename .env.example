# Copy to .env and fill in. .env is gitignored — see SECURITY.md.
# DO NOT commit this file with real values. Rotate any key that ever
# appeared in a commit (even a deleted one) — it is compromised.

# Cloud LLM adapters — set the one(s) you'll use
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local Llama path (only needed if installed with [local] extra)
# Point at a GGUF file on disk
LLAMA_MODEL_PATH=

# Default model selection for `regrag query`
# One of: anthropic, openai, llama_local
REGRAG_DEFAULT_MODEL=anthropic
REGRAG_ANTHROPIC_MODEL=claude-sonnet-4-6
REGRAG_OPENAI_MODEL=gpt-4o

# Vector store location (Chroma persistent dir)
REGRAG_CHROMA_DIR=.chroma

# Audit log destination (jsonl file or directory)
REGRAG_AUDIT_LOG=audit.jsonl
